{
  // Web is a Vite bundler target, not a Node service: override the base's NodeNext
  // module resolution with Bundler (Vite's recommended setting) so relative imports
  // need no .js extension. `vite/client` supplies ambient types for CSS/asset
  // side-effect imports (e.g. import './styles/global.css').
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    // `node` is needed by the Playwright specs + config under tests/ (process.env,
    // the Node-side test runner); `rootDir` is dropped so tests/ (a sibling of src)
    // is allowed in `include` — safe because the build is `tsc --noEmit`.
    "types": ["vite/client", "node"]
  },
  "include": ["src", "tests", "playwright.config.ts"]
}
