# Hivly — secrets (example)
#
# Copy to `.env` and fill with real values:
#   cp .env.example .env
#
# This file holds SECRETS ONLY (tokens, API keys, connection URLs). Behavior
# config (channels, models, RBAC, tuning) lives ONLY in `Hivly.config.yml`,
# which references these as ${VAR}. Never mix the two (AD Consistency Conventions).

# --- Discord app / bot credentials -------------------------------------------
DISCORD_BOT_TOKEN=your-discord-bot-token           # Bot token from the Discord developer portal
DISCORD_CLIENT_ID=000000000000000000               # OAuth2 application (client) ID
DISCORD_CLIENT_SECRET=your-discord-client-secret   # OAuth2 client secret (login flow)
DISCORD_GUILD_ID=000000000000000000                # Target guild (server) snowflake

# --- LLM & embeddings ---------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx       # RAG agent provider (default: claude-sonnet-4-6)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx              # Embeddings (text-embedding-3-small, 1536 dims)

# --- PostgreSQL + pgvector ----------------------------------------------------
DATABASE_URL=postgres://hivly:changeme@localhost:5432/hivly  # App + pgvector connection string
POSTGRES_PASSWORD=changeme                          # Password for the postgres service (docker compose)

# --- Redis (sessions + streams) ----------------------------------------------
REDIS_URL=redis://localhost:6379                    # Sessions (AD-10) and Redis Streams (AD-13)

# --- Web session --------------------------------------------------------------
SESSION_SECRET=change-me-to-a-long-random-string    # express-session signing secret

# --- Web / CORS ---------------------------------------------------------------
FRONTEND_URL=http://localhost:5173                  # Allowed CORS origin / SPA origin (Vite in dev)

# --- Observability (optional) -------------------------------------------------
SENTRY_DSN=                                         # Sentry DSN; leave empty to disable

# --- External notifications (optional; used in Epic 6) ------------------------
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token         # Telegram notifications
# TELEGRAM_CHAT_ID=000000000                         # Telegram target chat
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx                   # Slack notifications
