# Share2Brain — secrets (example)
#
# Copy to `.env` and fill with real values:
#   cp .env.example .env
#
# This file holds SECRETS ONLY (tokens, API keys, connection URLs). Behavior
# config (channels, models, RBAC, tuning) lives ONLY in `Share2Brain.config.yml`,
# which references these as ${VAR}. Never mix the two (AD Consistency Conventions).

# --- Discord app / bot credentials -------------------------------------------
DISCORD_BOT_TOKEN=your-discord-bot-token           # Bot token from the Discord developer portal
DISCORD_CLIENT_ID=000000000000000000               # OAuth2 application (client) ID
DISCORD_CLIENT_SECRET=your-discord-client-secret   # OAuth2 client secret (login flow)
DISCORD_GUILD_ID=000000000000000000                # Target guild (server) snowflake
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/callback  # OAuth2 callback (dev: through the Vite proxy so the sid cookie lands on :5173; prod: public origin behind nginx). Must match the redirect registered in the Discord app.

# --- LLM & embeddings ---------------------------------------------------------
# LLM (RAG agent) — required for any agent.provider (anthropic/openai/custom).
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx             # agent.api_key
LLM_BASE_URL=                                       # agent.base_url — leave blank unless provider is "custom"
# Embeddings — required for embeddings.provider (openai/custom).
EMBEDDINGS_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx          # embeddings.api_key (text-embedding-3-small, 1536 dims)
EMBEDDINGS_BASE_URL=                                # embeddings.base_url — leave blank unless provider is "custom"
# Enrichment (Epic 7 — AI-curated resource index) — required, enrichment.llm.provider.
ENRICHMENT_LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx  # enrichment.llm.api_key (may reuse LLM_API_KEY's value locally)
ENRICHMENT_LLM_BASE_URL=                            # enrichment.llm.base_url — leave blank unless provider is "custom"

# --- PostgreSQL + pgvector ----------------------------------------------------
DATABASE_URL=postgres://share2brain:changeme@localhost:5432/share2brain  # App + pgvector connection string
POSTGRES_PASSWORD=changeme                          # Password for the postgres service (docker compose)

# --- Redis (sessions + streams) ----------------------------------------------
REDIS_URL=redis://:change-me-to-a-long-random-string@localhost:6379  # Sessions (AD-10) and Redis Streams (AD-13). Redis requires AUTH: keep the password here in sync with REDIS_PASSWORD below. Used by local `npm run dev` (compose publishes redis on 127.0.0.1:6379); in Docker the app services use redis://:${REDIS_PASSWORD}@redis:6379 (set in docker-compose.yml).
REDIS_PASSWORD=change-me-to-a-long-random-string    # Redis AUTH password (docker compose --requirepass). Use a long random value in prod; must match the password embedded in the Docker REDIS_URL.

# --- Web session --------------------------------------------------------------
SESSION_SECRET=change-me-to-a-long-random-string    # express-session signing secret
SESSION_TTL_DAYS=7                                  # session lifetime in days (Redis TTL + cookie maxAge)

# --- Web / CORS ---------------------------------------------------------------
FRONTEND_URL=http://localhost:5173                  # Allowed CORS origin / SPA origin (Vite in dev)

# --- Web build-time (Vite) ----------------------------------------------------
# Community name shown in the SPA header. Build-time only (AD-3: the static bundle
# can't read Share2Brain.config.yml). VITE_-prefixed vars are inlined into the bundle.
VITE_COMMUNITY_NAME=Share2Brain                            # e.g. "Aurora Labs"

# --- Observability (optional) -------------------------------------------------
# Sentry DSN; leave empty to disable (inline comment omitted on purpose: an empty
# value + inline comment makes Docker Compose treat the "#..." text as the value).
SENTRY_DSN=

# --- External notifications (optional; Story 6.4, FR21) -----------------------
# Only required when Share2Brain.config.yml's notifications.enabled is true. Fill in
# the pair matching notifications.provider ("telegram" or "slack") and leave the
# other commented out — Share2Brain.config.yml only references the active provider's
# ${VAR}s, so an unused pair can stay unset.
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token          # Telegram bot token (BotFather)
# TELEGRAM_CHAT_ID=000000000                          # Telegram target chat id
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz  # Slack incoming webhook URL
