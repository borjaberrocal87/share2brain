# Keep the root build context small. Everything a service image needs is copied
# explicitly in its Dockerfile; these never belong in an image.
**/node_modules
**/dist
.git
.gitignore
_bmad
_bmad-output
docs
.claude
.agents
.opencode
*.log
.env
.env.*
!.env.example
Share2Brain.config.yml
.DS_Store
*.tsbuildinfo
