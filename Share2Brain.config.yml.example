# Share2Brain — behavior configuration (example)
#
# Copy to `Share2Brain.config.yml` and edit with real values:
#   cp Share2Brain.config.yml.example Share2Brain.config.yml
#
# This file holds BEHAVIOR only (channels, models, RBAC, enrichment tuning,
# rate limits). Secrets (tokens, API keys, DB/Redis URLs) live ONLY in `.env`
# and are referenced here as ${...} placeholders. Never mix the two (AD Consistency
# Conventions). Validated by `loadConfig()` in `@share2brain/shared`; the service
# aborts on invalid/missing keys before opening any connection.

version: "1.0"

# --- Discord ingestion --------------------------------------------------------
discord:
  guild_id: "${DISCORD_GUILD_ID}"
  channels:
    - id: "1234567890"
      name: "general"
      enabled: true
    - id: "1234567891"
      name: "support"
      enabled: true
  backfill:
    enabled: true       # index historical messages on first run
    limit: 1000         # max messages to backfill per channel
    ignore_bots: true

# --- RAG agent / LLM (LangGraph) ---------------------------------------------
# provider: "anthropic" | "openai" | "custom". "custom" is any OpenAI-compatible
# endpoint and REQUIRES base_url. api_key is a secret referenced from .env.
agent:
  provider: "anthropic"
  model: "claude-sonnet-4-6"
  temperature: 0.7
  max_iterations: 10
  memory_window: 20     # conversation turns kept before summarization
  api_key: "${LLM_API_KEY}"
  base_url: "${LLM_BASE_URL}"   # leave LLM_BASE_URL blank unless provider is "custom"

# --- Embeddings provider ------------------------------------------------------
# provider: "openai" | "custom" only — Anthropic has NO embeddings API.
# dimensions MUST match the model's output (text-embedding-3-small = 1536).
# Changing dimensions once embeddings exist requires a migration + reindex.
embeddings:
  provider: "openai"
  model: "text-embedding-3-small"
  dimensions: 1536
  api_key: "${EMBEDDINGS_API_KEY}"
  base_url: "${EMBEDDINGS_BASE_URL}"   # leave EMBEDDINGS_BASE_URL blank unless provider is "custom"

# --- Enrichment pipeline (Epic 7 — AI-curated resource index) ----------------
# REQUIRED — the Story 7.2 Indexer cannot run without it. Extracts URLs from
# messages, fetches the page, and generates title/description via an LLM.
# llm mirrors the `agent` block's shape (provider/model/temperature/base_url/
# api_key); language is the AI output language for the generated text.
enrichment:
  language: "en"
  llm:
    provider: "anthropic"
    model: "claude-sonnet-4-6"
    temperature: 0.3
    api_key: "${ENRICHMENT_LLM_API_KEY}"
    base_url: "${ENRICHMENT_LLM_BASE_URL}"   # leave blank unless provider is "custom"
  fetch:
    timeout_ms: 5000        # per-request outbound fetch timeout
    max_bytes: 2000000      # cap on downloaded page size (~2MB)
    max_redirects: 3
    user_agent: "Share2BrainBot/1.0"
    allowed_schemes: ["https"]
    block_private_ips: true   # SSRF mitigation (Story 7.2)
  # OPTIONAL — throttle enrichment LLM calls so a burst of link-heavy messages
  # can't run up cost / hit provider limits. Omit the whole block to disable.
  rate_limit:
    enabled: true
    per_author_hourly: 20   # max enrichments triggered by one Discord author per hour
    global_daily: 500       # max enrichments across the whole instance per day

# --- Sync (edits/deletes from Discord) ---------------------------------------
sync:
  enabled: true
  sync_on_start: true
  delete_policy: "soft" # "soft" (deleted_at) | "hard" (DELETE row)

# --- Redis Streams retention (Story OPS-1) -----------------------------------
# Bounds the Redis Streams so a long-running instance can't grow Redis memory
# without limit. The primary trim is PEL-safe (XTRIM MINID at the oldest entry
# still needed by any consumer group) and NEVER drops an unacked entry — it applies
# to streams that HAVE a consumer group. max_len is an OPTIONAL APPROXIMATE (~)
# ceiling backstop for a stuck/dead consumer (or a stream with no consumer group,
# e.g. knowledge:events): null = off (recommended; the PEL-safe floor is the only
# bound). Setting a number may drop pending entries when hit, and logs a warning.
streams:
  trim_enabled: true
  trim_interval_ms: 300000 # 5 minutes
  max_len: null

# --- Access control / RBAC ----------------------------------------------------
# channel_permissions is materialized into the `channel_permissions` table at
# Backend startup; allowedChannelIds is expanded per request (AD-12), so changes
# here take effect on the user's next request after a restart.
access_control:
  enabled: true
  default_policy: "deny"
  role_cache_ttl: 300   # seconds (user_roles_cache TTL)
  # NEW — guest access for demos. OFF by default (never auth-bypass in prod).
  guest_access:
    enabled: false            # operator sets true only for the demo
    role: "guest"             # synthetic role; add it to allowed_roles of demo channels
    username: "Invitado"      # display name in the UI
    session_ttl_minutes: 120  # short-lived demo session
    invite_url: "https://discord.gg/xxxxxxxx"   # optional — demo server invite shown on the login screen
  channel_permissions:
    - channel_id: "1234567890"
      name: "general"
      allowed_roles: ["admin", "mod", "member", "guest"]  # + guest for demo

# --- Read tracking ------------------------------------------------------------
read_tracking:
  enabled: true
  auto_mark_read_on_click: true

# UI language (Epic 10). Optional block; if absent -> "es".
# Governs ONLY the SPA (literals, date/number formatting, client-side
# error messages). The AI-generated content language remains
# enrichment.language.
ui:
  language: "es"             # es | en

# --- Observability ------------------------------------------------------------
observability:
  sentry_dsn: "${SENTRY_DSN}"
  log_level: "info"     # debug | info | warn | error

# --- Security -----------------------------------------------------------------
security:
  # OPTIONAL — session cookie `Secure` attribute. Omit (or true) = cookie is
  # only sent over HTTPS (the safe production default). Set false ONLY for local
  # plain-HTTP dev, where a Secure cookie would never be stored by the browser.
  # cookie_secure: true
  # Three independent tiers (Story 6.4, AC-2), each { window_ms, max_requests }.
  # Keyed per client IP (trust proxy 1, the single nginx hop). /health is never
  # rate-limited.
  rate_limit:
    api:
      window_ms: 900000   # 15 min
      max_requests: 100
    auth:
      window_ms: 900000   # 15 min
      max_requests: 10
    chat:
      window_ms: 60000    # 1 min
      max_requests: 20
  allowed_origins:
    - "${FRONTEND_URL}"  # dev: Vite origin; prod: served behind nginx

# --- External notifications (FR21, Story 6.4) ---------------------------------
# Crash alerts (uncaughtException/unhandledRejection/fatal-shutdown) sent
# directly via HTTP from each service (bot/backend/workers) — NOT through the
# reserved share2brain:knowledge:events stream. Behavior only (enabled, provider)
# lives here; credentials are secrets and live ONLY in .env. Never mix the two
# (AD Consistency Conventions).
#
# NOTE: interpolateEnv substitutes placeholders across the WHOLE raw file
# BEFORE YAML parsing, including inside comments — so an env-var placeholder
# written in a comment below would still abort startup if unset. The two
# credential blocks are therefore left out entirely while disabled; add ONE of
# them (matching `provider`) only once you also set its secret(s) in .env — see
# the "External notifications" section there for the exact variable names and
# the placeholder syntax to use here.
notifications:
  enabled: false
  provider: "telegram"   # "telegram" | "slack" — only enforced when enabled: true
