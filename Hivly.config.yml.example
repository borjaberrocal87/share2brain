# Hivly — behavior configuration (example)
#
# Copy to `Hivly.config.yml` and edit with real values:
#   cp Hivly.config.yml.example Hivly.config.yml
#
# This file holds BEHAVIOR only (channels, models, RBAC, knowledge tuning,
# rate limits). Secrets (tokens, API keys, DB/Redis URLs) live ONLY in `.env`
# and are referenced here as ${...} placeholders. Never mix the two (AD Consistency
# Conventions). Validated by `loadConfig()` in `@hivly/shared`; the service
# aborts on invalid/missing keys before opening any connection.

version: "1.0"

# --- Discord ingestion --------------------------------------------------------
discord:
  guild_id: "${DISCORD_GUILD_ID}"
  channels:
    - id: "1234567890"
      name: "general"
      enabled: true
    - id: "1234567891"
      name: "support"
      enabled: true
  backfill:
    enabled: true       # index historical messages on first run
    limit: 1000         # max messages to backfill per channel
    ignore_bots: true

# --- RAG agent / LLM (LangGraph) ---------------------------------------------
# provider: "anthropic" | "openai" | "custom". "custom" is any OpenAI-compatible
# endpoint and REQUIRES base_url. api_key is a secret referenced from .env.
agent:
  provider: "anthropic"
  model: "claude-sonnet-4-6"
  temperature: 0.7
  max_iterations: 10
  memory_window: 20     # conversation turns kept before summarization
  api_key: "${LLM_API_KEY}"
  base_url: "${LLM_BASE_URL}"   # leave LLM_BASE_URL blank unless provider is "custom"

# --- Embeddings provider ------------------------------------------------------
# provider: "openai" | "custom" only — Anthropic has NO embeddings API.
# dimensions MUST match the model's output (text-embedding-3-small = 1536).
# Changing dimensions once embeddings exist requires a migration + reindex.
embeddings:
  provider: "openai"
  model: "text-embedding-3-small"
  dimensions: 1536
  api_key: "${EMBEDDINGS_API_KEY}"
  base_url: "${EMBEDDINGS_BASE_URL}"   # leave EMBEDDINGS_BASE_URL blank unless provider is "custom"

# --- Knowledge / ingestion tuning --------------------------------------------
knowledge:
  chunk_size: 500
  chunk_overlap: 50
  grouping_window: 10   # consecutive same-channel messages grouped before chunking

# --- Sync (edits/deletes from Discord) ---------------------------------------
sync:
  enabled: true
  sync_on_start: true
  delete_policy: "soft" # "soft" (deleted_at) | "hard" (DELETE row)

# --- Access control / RBAC ----------------------------------------------------
# channel_permissions is materialized into the `channel_permissions` table at
# Backend startup; allowedChannelIds is expanded per request (AD-12), so changes
# here take effect on the user's next request after a restart.
access_control:
  enabled: true
  default_policy: "deny"
  role_cache_ttl: 300   # seconds (user_roles_cache TTL)
  channel_permissions:
    - channel_id: "1234567890"
      name: "general"
      allowed_roles: ["admin", "mod", "member"]

# --- Read tracking ------------------------------------------------------------
read_tracking:
  enabled: true
  auto_mark_read_on_click: true

# --- Observability ------------------------------------------------------------
observability:
  sentry_dsn: "${SENTRY_DSN}"
  log_level: "info"     # debug | info | warn | error

# --- Security -----------------------------------------------------------------
security:
  # Three independent tiers (Story 6.4, AC-2), each { window_ms, max_requests }.
  # Keyed per client IP (trust proxy 1, the single nginx hop). /health is never
  # rate-limited.
  rate_limit:
    api:
      window_ms: 900000   # 15 min
      max_requests: 100
    auth:
      window_ms: 900000   # 15 min
      max_requests: 10
    chat:
      window_ms: 60000    # 1 min
      max_requests: 20
  allowed_origins:
    - "${FRONTEND_URL}"  # dev: Vite origin; prod: served behind nginx

# --- External notifications (FR21, Story 6.4) ---------------------------------
# Crash alerts (uncaughtException/unhandledRejection/fatal-shutdown) sent
# directly via HTTP from each service (bot/backend/workers) — NOT through the
# reserved hivly:knowledge:events stream. Behavior only (enabled, provider)
# lives here; credentials are secrets and live ONLY in .env. Never mix the two
# (AD Consistency Conventions).
#
# NOTE: interpolateEnv substitutes placeholders across the WHOLE raw file
# BEFORE YAML parsing, including inside comments — so an env-var placeholder
# written in a comment below would still abort startup if unset. The two
# credential blocks are therefore left out entirely while disabled; add ONE of
# them (matching `provider`) only once you also set its secret(s) in .env — see
# the "External notifications" section there for the exact variable names and
# the placeholder syntax to use here.
notifications:
  enabled: false
  provider: "telegram"   # "telegram" | "slack" — only enforced when enabled: true
